{
  "rabbit_version": "3.12.0",
  "rabbitmq_version": "3.12.0",
  "product_name": "RabbitMQ",
  "product_version": "3.12.0",
  "vhosts": [
    { "name": "/" }
  ],
  "permissions": [
    {
      "user": "admin",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "topic_permissions": [],
  "parameters": [],
  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "food-delivery@rabbitmq"
    }
  ],
  "policies": [],
  "exchanges": [
    {
      "name": "order.events",
      "vhost": "/",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "orders.notification",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "orders.driver-assign",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "order.events",
      "vhost": "/",
      "destination": "orders.notification",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "order.events",
      "vhost": "/",
      "destination": "orders.driver-assign",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    }
  ]
}
